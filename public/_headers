# Vantage — Netlify response headers

# Service worker: must be served from root scope with correct MIME type
/sw.js
  Content-Type: application/javascript; charset=utf-8
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /

# Web app manifest
/manifest.json
  Content-Type: application/manifest+json; charset=utf-8
  Cache-Control: public, max-age=86400

# Icons
/icon-192.png
  Cache-Control: public, max-age=2592000, immutable
/icon-512.png
  Cache-Control: public, max-age=2592000, immutable
/apple-touch-icon.png
  Cache-Control: public, max-age=2592000, immutable

# All pages: security headers + allow SW registration
# SAMEORIGIN (not DENY): the owner Rotation section renders
# /schedule/shift-rotation-2026.html in a same-origin iframe; DENY
# blocks even that. Cross-origin embedding stays blocked.
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(self), microphone=(), geolocation=()
